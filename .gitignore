# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# VSCode test binaries (very large)
.vscode-test/

# Distribution / packaging
*.egg-info/
dist/
build/

# Python wheels (both local builds and downloaded)
*.whl
*.whl.*

# Rust wheels (maturin output)
pyneat-rs/target/wheels/

# Rust target (local build artifacts) - includes .pdb files which can be 80MB+
pyneat-rs/target/

# Logs
*.log
pyneat_errors.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.cursor/

# Rust build (local)
pyneat-rs/target/

# Test artifacts
*.clean.py
*_cleaned.py
*_output.txt
*.bak
