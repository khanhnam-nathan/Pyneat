# =============================================
# .gitignore - PyNEAT Development
# =============================================
#
# This file excludes:
# - Build artifacts (dist/, pyneat-rs/target/)
# - Debug/test scripts (debug*.py, test*.py, analyze*.py)
# - Fuzzing results (pyneat_fuzz_results/)
# - IDE-specific files
# - Batch scripts
#
# This file INCLUDES:
# - All source code (pyneat/, pyneat-rs/src/)
# - All tests (tests/)
# - Configuration files (.pre-commit-config.yaml, pyproject.toml)
# - Documentation (.github/, .gitlab-ci/)
# - Ecosystem files (vscode-extension/, jetbrains-plugin/, vim-plugin/)
#
# =============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
*.egg-info/
dist/
build/

# Rust build artifacts
pyneat-rs/target/
pyneat-rs/Cargo.lock

# Python compiled extensions
*.so
*.pyd

# Logs
*.log
pyneat_errors.log

# OS files
.DS_Store
Thumbs.db

# IDE - Only exclude settings, keep workspace
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Test artifacts
*.clean.py
*_cleaned.py
*_output.txt
*.bak

# Debug and test files (development only)
# These are useful for local development but shouldn't be in the repo
*.py.bak
analyze_*.py
debug*.py
check_*.py
test_*.py
demo_*.py
test_samples/

# Fuzz results (generated by fuzzing)
pyneat_fuzz_results/
pyneat_rs/
pyneat_fuzz_results/

# Batch scripts (development only)
*.bat

# Cursor IDE (local settings)
.cursor/

# Wheels (build locally)
*.whl

# Virtual environments
venv/
.env/
.venv/

# Coverage
.coverage
htmlcov/
.pytest_cache/
