# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# VSCode test binaries (very large)
.vscode-test/

# Distribution / packaging
*.egg-info/
dist/
build/

# Python wheels (both local builds and downloaded)
*.whl
*.whl.*

# Rust wheels (maturin output)
pyneat-rs/target/wheels/

# Rust target (local build artifacts) - includes .pdb files which can be 80MB+
pyneat-rs/target/

# Logs
*.log
pyneat_errors.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.cursor/

# Rust build (local)
pyneat-rs/target/

# Test artifacts
*.clean.py
*_cleaned.py
*_output.txt
*.bak

# =============================================================================
# PROPRIETARY / SECURITY EXCLUSIONS
# =============================================================================

# PyNeat Pro Engine - PROPRIETARY, DO NOT COMMIT
# The pyneat-pro-engine directory is located at D:\pyneat-pro-engine
pyneat-workspace/pyneat-pro-engine/

# Binary files from any Rust compilation (pre-built or accidentally committed)
*.exe
*.dll
*.so
*.dylib
*.pdb

# Rust release binaries
target/release/pyneat*
target/debug/pyneat*
pyneat-workspace/target/
**/target/release/**
**/target/debug/**

# Any file containing "pro-engine" in the name
*pro*engine*
*pro_engine*
*proprietary*

# License files that might indicate proprietary code
*PROPRIETARY*
*LICENSE_PROPRIETARY*
*COMMERCIAL*
